# BENCHMARK LOADERS
# =============================================================================
class BenchmarkDataset:
    def __init__(self, name: str): self.name = name; self.data = None
    def load(self): raise NotImplementedError
    def get_texts(self, mode: str):
        if self.data is None: self.load()
        texts, ids = [], []
        for i, item in enumerate(self.data):
            item_id = item.get('id', f"item_{i}")
            if mode == 'input': t = item['input']
            elif mode == 'output': t = item['output']
            elif mode == 'input_output': t = f"{item['input']}\n\n{item['output']}"
            texts.append(t); ids.append(item_id)
        return texts, ids

class MuSRDataset(BenchmarkDataset):
    def __init__(self): super().__init__("MuSR")
    def load(self):
        print(f"Loading {self.name}...")
        ds = load_dataset("TAUR-Lab/MuSR")
        self.data = []
        for split, d in ds.items():
            for idx, item in enumerate(d):
                self.data.append({'id': f"{split}_{idx}", 'input': item.get('narrative', item.get('question','')), 'output': item.get('answer','')})

class HumanEvalDataset(BenchmarkDataset):
    def __init__(self): super().__init__("HumanEval")
    def load(self):
        print(f"Loading {self.name}...")
        ds = load_dataset("openai/openai_humaneval")
        self.data = []
        for split, d in ds.items():
            for item in d:
                self.data.append({'id': item.get('task_id'), 'input': item.get('prompt',''), 'output': item.get('canonical_solution','')})

class MBPPDataset(BenchmarkDataset):
    def __init__(self): super().__init__("MBPP")
    def load(self):
        print(f"Loading {self.name} (via evalplus/mbpp)...")
        try:
            ds = load_dataset("evalplus/mbpp", "mbpp")
        except Exception as e:
            print(f"Fallback to google-research-datasets/mbpp due to: {e}")
            ds = load_dataset("google-research-datasets/mbpp", "sanitized", trust_remote_code=True)

        self.data = []
        target_split = 'test' if 'test' in ds else list(ds.keys())[0]
        
        for item in ds[target_split]:
            input_text = item.get('prompt') or item.get('text') or ''
            output_code = item.get('canonical_solution') or item.get('code') or item.get('solution') or ''
            self.data.append({
                'id': str(item.get('task_id')),
                'input': input_text,
                'output': output_code
            })

# =============================================================================
# EMBEDDING ENGINE
# =============================================================================
class EmbeddingEngine:
    def __init__(self, config):
        self.config = config
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.tokenizer = AutoTokenizer.from_pretrained(config.model_name, trust_remote_code=True)
        self.model = AutoModel.from_pretrained(config.model_name, torch_dtype=torch.float16, trust_remote_code=True).to(self.device).eval()

    @torch.inference_mode()
    def embed_texts(self, texts):
        res = []
        for i in tqdm(range(0, len(texts), self.config.embedding_batch_size), desc="Embedding"):
            batch = texts[i:i+self.config.embedding_batch_size]
            enc = self.tokenizer(batch, padding=True, truncation=True, max_length=self.config.max_seq_length, return_tensors='pt').to(self.device)
            out = self.model(**enc)
            mask = enc['attention_mask'].unsqueeze(-1).expand(out[0].size()).float()
            emb = torch.sum(out[0] * mask, dim=1) / torch.clamp(mask.sum(dim=1), min=1e-9)
            res.append(F.normalize(emb, p=2, dim=1).cpu())
        return torch.cat(res, dim=0).float().numpy()

    def unload(self):
        del self.model
        del self.tokenizer
        gc.collect()
        torch.cuda.empty_cache()

# =============================================================================
# ASYNC I/O DATA MANAGER
# =============================================================================
class AsyncDiskDataManager:
    def __init__(self, config): 
        self.config = config
        self.files = sorted(Path(self.config.local_data_dir).rglob("*.parquet"))
        self.queue = queue.Queue(maxsize=self.config.prefetch_size)
        self.stop_event = threading.Event()

    def _scavenge_file(self, file_path, cols_to_read, id_col_name, src_col_name):
        """Attempts to read file row-group-by-row-group to salvage data if full read fails.
        Returns raw arrays instead of concatenating to avoid offset overflow."""
        all_embeddings = []
        all_ids = []
        all_sources = []
        
        try:
            pf = pq.ParquetFile(file_path)
            
            for i in range(pf.num_row_groups):
                try:
                    chunk = pf.read_row_group(i, columns=cols_to_read)
                    
                    if 'embeddings' not in chunk.column_names:
                        continue
                    
                    emb_col = chunk['embeddings']
                    # Process each chunk without combining
                    for j in range(emb_col.num_chunks):
                        arr = emb_col.chunk(j)
                        if len(arr) == 0:
                            continue
                        
                        vals = arr.values.to_numpy()
                        chunk_len = len(arr)
                        dim = len(vals) // chunk_len
                        mat = vals.reshape(chunk_len, dim).astype(np.float32)
                        mat = mat / np.maximum(np.linalg.norm(mat, axis=1, keepdims=True), 1e-9)
                        all_embeddings.append(mat)
                        
                        # Extract IDs if available
                        if id_col_name and id_col_name in chunk.column_names:
                            all_ids.extend(chunk[id_col_name].to_pylist()[:chunk_len])
                        else:
                            all_ids.extend([f"scav_{i}_{j}_{k}" for k in range(chunk_len)])
                        
                        # Extract sources if available
                        if src_col_name and src_col_name in chunk.column_names:
                            all_sources.extend(chunk[src_col_name].to_pylist()[:chunk_len])
                        else:
                            all_sources.extend(["unknown"] * chunk_len)
                            
                except Exception:
                    continue  # Skip bad row group, keep good ones
            
            if not all_embeddings:
                return None, None, None, None
            
            # Return stacked embeddings and metadata
            final_mat = np.vstack(all_embeddings) if len(all_embeddings) > 1 else all_embeddings[0]
            return final_mat, all_ids, all_sources, True  # True = already processed
            
        except Exception:
            return None, None, None, None

    def _read_worker(self, start_idx):
        for idx, f in enumerate(self.files):
            if idx < start_idx: continue
            if self.stop_event.is_set(): break

            try:
                # 1. Inspect Schema - use schema_arrow for TOP-LEVEL column names!
                # pf.schema.names gives leaf names (e.g., 'element' for fixed_size_list)
                # pf.schema_arrow gives actual column names (e.g., 'embeddings')
                try:
                    pf = pq.ParquetFile(str(f))
                    schema_cols = [field.name for field in pf.schema_arrow]
                except Exception:
                    try:
                        pf_fp = fastparquet.ParquetFile(str(f))
                        schema_cols = pf_fp.columns
                    except Exception:
                        # Total corruption
                        print(f"  💀 DEAD FILE: {f.name}")
                        continue

                # 2. Check for embeddings column first!
                if 'embeddings' not in schema_cols:
                    # Skip files without embeddings - they're probably raw data files
                    continue
                
                # 3. Identify ID and Source Columns
                id_col_name = None
                for candidate in ['id', 'hash_id', 'doc_hash', 'key', 'doc_id']:
                    if candidate in schema_cols:
                        id_col_name = candidate
                        break
                src_col_name = 'source' if 'source' in schema_cols else None
                
                cols_to_read = ['embeddings']
                if id_col_name: cols_to_read.append(id_col_name)
                if src_col_name: cols_to_read.append(src_col_name)

                # 3. Try Reads (PyArrow -> FastParquet -> Scavenge)
                t = None
                scavenged = False
                mat = None
                id_col = []
                src_col = []
                
                try:
                    t = pq.read_table(str(f), columns=cols_to_read)
                except Exception:
                    try:
                        # FastParquet Fallback
                        df = fastparquet.ParquetFile(str(f)).to_pandas(columns=cols_to_read)
                        t = pa.Table.from_pandas(df)
                    except Exception:
                        # Scavenge Mode - returns already-processed data
                        result = self._scavenge_file(str(f), cols_to_read, id_col_name, src_col_name)
                        if result[0] is not None:
                            mat, id_col, src_col, scavenged = result
                        else:
                            continue

                # If we got a table (not scavenged), process it
                if not scavenged:
                    if t is None or 'embeddings' not in t.column_names:
                        continue

                    # 4. Standardize Data - AVOID combine_chunks() to prevent overflow!
                    emb = t['embeddings']
                    
                    # Process chunks individually to avoid 32-bit offset overflow
                    all_mats = []
                    total_rows = 0
                    dim = None
                    
                    for chunk_idx in range(emb.num_chunks):
                        arr = emb.chunk(chunk_idx)
                        chunk_len = len(arr)
                        if chunk_len == 0:
                            continue
                        
                        vals = arr.values.to_numpy()
                        if dim is None:
                            dim = len(vals) // chunk_len
                        
                        chunk_mat = vals.reshape(chunk_len, dim).astype(np.float32)
                        chunk_mat = chunk_mat / np.maximum(np.linalg.norm(chunk_mat, axis=1, keepdims=True), 1e-9)
                        all_mats.append(chunk_mat)
                        total_rows += chunk_len
                    
                    if not all_mats or total_rows == 0:
                        continue
                    
                    # Stack all normalized chunks
                    mat = np.vstack(all_mats) if len(all_mats) > 1 else all_mats[0]
                    
                    # Extract Metadata
                    id_col = t[id_col_name].to_pylist() if id_col_name and id_col_name in t.column_names else []
                    src_col = t[src_col_name].to_pylist() if src_col_name and src_col_name in t.column_names else []
                
                rows = len(mat)

                # Align Lengths (Fix List Overflow)
                if len(id_col) < rows: id_col.extend([f"missing_{idx}_{i}" for i in range(rows - len(id_col))])
                elif len(id_col) > rows: id_col = id_col[:rows]

                if len(src_col) < rows: src_col.extend(["unknown"] * (rows - len(src_col)))
                elif len(src_col) > rows: src_col = src_col[:rows]

                f_name_short = os.path.basename(f.name)
                meta_chunk = list(zip([f_name_short]*rows, id_col, src_col))

                # Push to Queue (Block if full)
                self.queue.put((mat, meta_chunk, idx, f))

            except Exception as e:
                print(f"  ⚠️ Logic Error {f.name}: {e}")
                continue
        
        # Signal Done
        self.queue.put(None)

    def stream(self, start_idx=0):
        # Start background thread
        t = threading.Thread(target=self._read_worker, args=(start_idx,), daemon=True)
        t.start()
        
        pbar = tqdm(total=len(self.files), initial=start_idx, desc="Streaming (Async)")
        
        while True:
            item = self.queue.get()
            if item is None:
                break
            
            mat, meta, idx, f = item
            
            # Flush metadata immediately to save RAM
            self._flush_chunk(idx, meta)
            
            yield mat, idx, f
            pbar.update(1)
            
            del mat, meta
            
        pbar.close()
        self.stop_event.set()

    def _flush_chunk(self, chunk_id, data):
        p = self.config.meta_dir / f"meta_{chunk_id}.pkl"
        with open(p, 'wb') as f: pickle.dump(data, f)

    def get_meta_batch(self, chunk_ids_needed):
        cache = {}
        for cid in chunk_ids_needed:
            p = self.config.meta_dir / f"meta_{cid}.pkl"
            if p.exists():
                with open(p, 'rb') as f: cache[cid] = pickle.load(f)
        return cache

# =============================================================================
# ANALYZER
# =============================================================================
class SimilarityAnalyzer:
    def __init__(self, config, s3_manager):
        self.config = config
        self.s3 = s3_manager
        self.device = torch.device("cuda")

    @torch.inference_mode()
    def run(self, bench_emb, dm, files, d_name, mode):
        k = self.config.top_k_matches
        n_bench = len(bench_emb)
        
        ckpt_root = Path(self.config.checkpoint_dir)
        p_sims = ckpt_root / f"{d_name}_{mode}_sims.pt"
        p_idxs = ckpt_root / f"{d_name}_{mode}_idxs.pt"
        p_state = ckpt_root / f"{d_name}_{mode}_state.pkl"

        if p_sims.exists() and p_state.exists():
            print(f"Resuming {d_name} {mode}...")
            top_sims = torch.load(p_sims).to(self.device)
            top_idxs = torch.load(p_idxs).to(self.device)
            with open(p_state, 'rb') as f:
                state = pickle.load(f)
                start_f = state['last_f'] + 1
                off = state['off']
        else:
            top_sims = torch.full((n_bench, k), -1.0, device=self.device)
            top_idxs = torch.zeros((n_bench, k), device=self.device, dtype=torch.int64)
            start_f = 0; off = 0

        bench_gpu = torch.from_numpy(bench_emb).to(self.device)
        
        last_save_time = time.time()
        chunk_offsets = [] 
        
        if start_f > 0 and p_state.exists():
             with open(p_state, 'rb') as f:
                state = pickle.load(f)
                if 'chunk_offsets' in state: chunk_offsets = state['chunk_offsets']

        # Use ASYNC stream
        for corpus, f_idx, f_path in dm.stream(start_idx=start_f):
            n_corp = len(corpus)
            chunk_offsets.append((off, off + n_corp, f_idx))
            
            bs = self.config.compute_batch_size
            
            # Move large corpus chunk to GPU once if possible, or batch it
            # Optimizing for speed: minimize CPU-GPU transfers
            corpus_gpu = torch.from_numpy(corpus).to(self.device)
            
            for i in range(0, n_corp, bs):
                end = min(i+bs, n_corp)
                batch = corpus_gpu[i:end] # Slice on GPU is fast
                sims = torch.matmul(bench_gpu, batch.T)
                
                curr_idxs = torch.arange(off+i, off+end, device=self.device).unsqueeze(0).expand(n_bench, -1)
                
                cat_sims = torch.cat([top_sims, sims], dim=1)
                cat_idxs = torch.cat([top_idxs, curr_idxs], dim=1)
                
                top_sims, best = cat_sims.topk(k, dim=1)
                top_idxs = cat_idxs.gather(1, best)
                del sims, cat_sims, cat_idxs, best
            
            del corpus_gpu
            off += n_corp
            
            if time.time() - last_save_time >= self.config.save_every_seconds:
                self._ckpt(top_sims, top_idxs, f_idx, off, chunk_offsets, p_sims, p_idxs, p_state)
                last_save_time = time.time() 
                gc.collect()

        self._ckpt(top_sims, top_idxs, len(files)-1, off, chunk_offsets, p_sims, p_idxs, p_state)
        return top_sims.cpu().numpy(), top_idxs.cpu().numpy(), chunk_offsets

    def _ckpt(self, s, i, f, o, co, ps, pi, st):
        torch.save(s, ps); torch.save(i, pi)
        with open(st, 'wb') as f_out: pickle.dump({'last_f':f, 'off':o, 'chunk_offsets':co}, f_out)
        print(f"  [Time Checkpoint] Saved at file {f}")

    def resolve_and_save(self, top_sims, top_idxs, chunk_offsets, dm, d_name, mode):
        print("Resolving IDs...")
        needed_chunks = set()
        flat_idxs = top_idxs.flatten()
        flat_idxs.sort()
        
        resolved_map = {} 
        curr_chk_idx = 0
        for gid in tqdm(flat_idxs, desc="Mapping IDs"):
            if gid == 0 and len(chunk_offsets) == 0: continue
            while curr_chk_idx < len(chunk_offsets) and gid >= chunk_offsets[curr_chk_idx][1]:
                curr_chk_idx += 1
            if curr_chk_idx < len(chunk_offsets):
                start, end, cid = chunk_offsets[curr_chk_idx]
                if start <= gid < end:
                    needed_chunks.add(cid)
                    resolved_map[gid] = (cid, gid - start)

        print(f"Loading {len(needed_chunks)} metadata chunks...")
        meta_cache = dm.get_meta_batch(needed_chunks)
        
        matches_detailed = []
        for i in range(len(top_sims)):
            row_matches = []
            for r in range(len(top_sims[i])):
                score = float(top_sims[i][r])
                if score < 0: continue
                gid = top_idxs[i][r]
                if gid in resolved_map:
                    cid, rel_idx = resolved_map[gid]
                    if cid in meta_cache and rel_idx < len(meta_cache[cid]):
                        rec = meta_cache[cid][rel_idx] 
                        row_matches.append({
                            'rank': r+1, 'score': score,
                            'file': rec[0], 'id': rec[1], 'src': rec[2]
                        })
            matches_detailed.append(row_matches)

        local_base = Path(self.config.output_dir) / f"{d_name}_{mode}"
        np.save(f"{local_base}_top_k_sims.npy", top_sims)
        with open(f"{local_base}_matches.json", 'w') as f: json.dump(matches_detailed, f, indent=2)
        plt.figure(figsize=(10,6)); sns.histplot(top_sims[:, 0], bins=100)
        plt.savefig(f"{local_base}_dist.png"); plt.close()

        s3_base = f"{S3_PREFIX}/{d_name}/{mode}"
        self.s3.upload(f"{local_base}_top_k_sims.npy", f"{s3_base}/top_k_sims.npy")
        self.s3.upload(f"{local_base}_matches.json", f"{s3_base}/matches.json")
        self.s3.upload(f"{local_base}_dist.png", f"{s3_base}/dist.png")
        print(f"✅ {d_name} {mode} Complete.")

# =============================================================================
# MAIN
# =============================================================================
def main():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument('--dataset', nargs='+', default=['all'], help="all, musr, humaneval, mbpp")
    parser.add_argument('--modes', nargs='+', default=['input', 'output', 'input_output'])
    parser.add_argument('--data-dir', required=True)
    parser.add_argument('--bucket', default=S3_BUCKET_NAME)
    args = parser.parse_args()

    config = AnalysisConfig(local_data_dir=args.data_dir)
    s3 = S3Manager(args.bucket)
    
    cache = Path(config.output_dir) / "cache"
    cache.mkdir(exist_ok=True)
    
    # Determine datasets
    d_list = []
    ds_args = args.dataset if isinstance(args.dataset, list) else [args.dataset]
    
    if 'all' in ds_args:
        d_list = [MuSRDataset(), HumanEvalDataset(), MBPPDataset()]
    else:
        if 'musr' in ds_args: d_list.append(MuSRDataset())
        if 'humaneval' in ds_args: d_list.append(HumanEvalDataset())
        if 'mbpp' in ds_args: d_list.append(MBPPDataset())

    if not d_list:
        print("❌ No valid datasets selected.")
        return

    # Pre-embed Benchmarks
    engine = None
    for d in d_list:
        for m in args.modes:
            if not (cache / f"{d.name}_{m}_bench.npy").exists():
                print(f"Generating embeddings for {d.name} [{m}]...")
                if engine is None: engine = EmbeddingEngine(config)
                d.load()
                t, ids = d.get_texts(m)
                emb = engine.embed_texts(t)
                np.save(cache / f"{d.name}_{m}_bench.npy", emb)
    if engine: engine.unload()

    # Async Streaming & Analysis
    dm = AsyncDiskDataManager(config)
    
    # Check if we have files
    if not dm.files: return print("No files.")
    
    analyzer = SimilarityAnalyzer(config, s3)
    
    for d in d_list:
        for m in args.modes:
            print(f"\nProcessing {d.name} {m}")
            bench = np.load(cache / f"{d.name}_{m}_bench.npy")
            sims, idxs, chunks = analyzer.run(bench, dm, dm.files, d.name, m)
            analyzer.resolve_and_save(sims, idxs, chunks, dm, d.name, m)

if __name__ == "__main__":
    main()