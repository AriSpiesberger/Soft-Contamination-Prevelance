# API Keys for LLM providers
# Copy this file to .env and fill in your actual API keys

# OpenRouter API key (for embeddings and some model access)
OPENROUTER_API_KEY=your_openrouter_key_here

# Helicone API key (used for LLM generation calls via Helicone gateway)
HELICONE_API_KEY=your_helicone_key_here
HELICONE_BASE_URL=https://ai-gateway.helicone.ai

# Alternative: Direct API keys (if not using OpenRouter/Helicone)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
